//Consulta sin filtros
query {
    characters {
      id
      name
      status
      species
      gender
      origin {
        name
      }
    }
  }


//Consulta por especie especifica
query {
    characters(species: "Human") {
        id
        name
        species
    }
}


//Consulta por nombre
query {
    characters(name: "Rick") {
        id
        name
        status
        species
        gender
      origin {
            name
        }
    }
}

//Consulta por estado 
query {
